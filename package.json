{
  "name": "debuggle",
  "version": "0.1.0",
  "description": "Tu bóveda personal de errores de programación",
  "author": {
    "name": "D4vRAM369",
    "email": "d4vram369@users.noreply.github.com"
  },
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "test": "vitest run",
    "test:watch": "vitest",
    "pack:win": "electron-vite build && electron-builder --win",
    "pack:linux": "electron-vite build && electron-builder --linux AppImage deb rpm",
    "pack:linux:docker": "electron-vite build && electron-builder --linux AppImage deb rpm --docker",
    "pack:all": "electron-vite build && electron-builder --win --linux AppImage deb rpm"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.14.9",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/ui": "^4.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "jsdom": "^29.0.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.3",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.11.1",
    "keytar": "^7.9.0",
    "lucide-react": "^0.577.0",
    "openai": "^6.29.0",
    "radix-ui": "^1.4.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "build": {
    "appId": "dev.d4vram.debuggle",
    "productName": "Debuggle",
    "icon": "resources/icon.png",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "flatpak",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Development"
    },
    "flatpak": {
      "baseVersion": "23.08",
      "runtimeVersion": "23.08",
      "sdk": "org.freedesktop.Sdk",
      "runtime": "org.freedesktop.Platform",
      "branch": "stable",
      "finishArgs": [
        "--share=ipc",
        "--socket=x11",
        "--socket=wayland",
        "--socket=pulseaudio",
        "--share=network",
        "--device=dri",
        "--filesystem=home",
        "--talk-name=org.freedesktop.secrets",
        "--talk-name=org.gnome.keyring.*"
      ]
    },
    "deb": {
      "depends": [
        "libsecret-1-0"
      ]
    },
    "rpm": {
      "depends": [
        "libsecret"
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "D4vRAM369",
      "repo": "debuggle",
      "releaseType": "release"
    }
  }
}
